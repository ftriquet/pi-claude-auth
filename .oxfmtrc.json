{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "useTabs": false,
    "tabWidth": 4,
    "printWidth": 80,
    "singleQuote": false,
    "jsxSingleQuote": false,
    "quoteProps": "as-needed",
    "trailingComma": "all",
    "semi": false,
    "arrowParens": "always",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "ignorePatterns": [
        "CHANGELOG.md",
        "AGENTS.md",
        "CLAUDE.md",
        ".claude",
        ".gitnexus",
        "graphify-out",
        "dist",
        "node_modules",
        "test-results"
    ]
}
