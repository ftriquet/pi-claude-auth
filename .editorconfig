root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 80

# justfile uses 4-space indentation for recipe bodies.
[justfile]
indent_style = space
indent_size = 4

# Markdown trailing whitespace is significant (hard line breaks).
[*.md]
trim_trailing_whitespace = false
