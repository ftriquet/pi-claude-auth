{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "categories": {
        "correctness": "error",
        "suspicious": "warn",
        "perf": "warn"
    },
    "rules": {
        "no-await-in-loop": "off",
        "unicorn/no-array-sort": "off"
    },
    "ignorePatterns": ["dist", "test-results"]
}
